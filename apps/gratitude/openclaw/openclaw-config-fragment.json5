// Add this fragment to your ~/.openclaw/openclaw.json
// It registers the two Telegram commands and tells the agent workspace
// where to find the SOUL.md that describes the gratitude API.
//
// Adjust the workspace path to match your actual repo location.

{
  agents: {
    list: [
      {
        id: "gratitude",
        workspace: "~/.openclaw/workspace-gratitude",  // populated by install-openclaw.sh
        model: "openrouter/anthropic/claude-3.5-haiku",
        tools: {
          profile: "minimal",
          allow: ["web_fetch", "exec"],  // web_fetch for log flow, exec for skill bash bypass
        },
      },
    ],
  },

  // Route only logging-bot messages to the gratitude agent
  bindings: [
    { agentId: "gratitude", match: { channel: "telegram", accountId: "logging-bot" } },
  ],

  channels: {
    telegram: {
      accounts: {
        "logging-bot": {
          botToken: "",  // set TELEGRAM_BOT_TOKEN_LOGGING_BOT or fill in here
          // Register the commands in the Telegram menu
          customCommands: [
            { command: "log_gratitude", description: "Log today's gratitude entry" },
            { command: "analytics_gratitude", description: "View your journaling stats" },
          ],
        },
      },
    },
  },
}
